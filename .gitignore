# ============================
# Dependencias (Node.js)
# ============================
node_modules/
frontend/node_modules/
backend/node_modules/

# ============================
# Archivos de entorno
# ============================
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# ============================
# Archivos de base de datos SQLite
# ============================
*.db
*.sqlite
*.sqlite3
backend/database/*.sqlite
backend/database/*.db

# ============================
# Archivos subidos al backend (audios, imágenes, PDFs)
# ============================
backend/uploads/
backend/uploads/**/*.mp3
backend/uploads/**/*.mp4
backend/uploads/**/*.m4a
backend/uploads/**/*.aac
backend/uploads/**/*.pdf
backend/uploads/**/*.jpg
backend/uploads/**/*.jpeg
backend/uploads/**/*.png
backend/uploads/**/*.webp

# ============================
# Archivos de compilación / empaquetado
# ============================
/build
/dist
/.cache
frontend/build/
frontend/dist/

# ============================
# Logs y archivos temporales
# ============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
tmp/
logs/
*.pid

# ============================
# Archivos de configuración de IDEs
# ============================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ============================
# Archivos del sistema operativo
# ============================
.DS_Store
Thumbs.db
desktop.ini

# ============================
# Archivos multimedia grandes (evitar)
# ============================
*.mp3
*.mp4
*.m4a
*.aac
*.webm
*.wav
*.flac
*.ogg
*.psd
*.tif
*.bmp

# ============================
# Archivos PDF y comprimidos
# ============================
*.pdf
*.zip
*.tar.gz
*.7z
*.rar
*.iso

# ============================
# Archivos de respaldo
# ============================
*.bak
*.backup
*.dump

# ============================
# Archivos temporales
# ============================
*.tmp
*.temp
*~
*.swp
*.swo

# ============================
